# ═══════════════════════════════════════════════════════════════
# A2Z WorkHub — Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="A2Z WorkHub"

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@workhub.a2z.com.vn

# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://...

# Cloudflare R2 (Large file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=a2z-workhub-files

# Cron & Webhooks (bảo vệ API endpoints)
CRON_SECRET=your-cron-secret-here
WEBHOOK_SECRET=your-webhook-secret-here
